// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  email        String   @unique
  name         String
  passwordHash String
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Client {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  name          String
  brandName     String
  industry      String?
  contactPerson String?
  email         String?
  phone         String?
  instagramUrl  String?
  facebookUrl   String?
  notes         String?
  brandGuidelines String?
  healthScore   Float    @default(0)
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  socialAccounts     SocialAccount[]
  analyticsSnapshots AnalyticsSnapshot[]
  calendarEntries    CalendarEntry[]
  contentLibrary     ContentItem[]
  aiReviews          AIReview[]
  reports            Report[]
  competitors        Competitor[]
  contentIdeas       ContentIdea[]
  notifications      Notification[]

  @@map("clients")
}

model SocialAccount {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId     String
  platform     String   // "instagram" | "facebook"
  username     String?
  profileUrl   String?
  profileImage String?
  bio          String?
  followers    Int      @default(0)
  following    Int      @default(0)
  totalPosts   Int      @default(0)
  pageLikes    Int      @default(0)
  isConnected  Boolean  @default(false)
  accessToken  String?
  lastSynced   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, platform])
  @@map("social_accounts")
}

model AnalyticsSnapshot {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId    String
  platform    String
  date        DateTime
  followers   Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  engagement  Float    @default(0)
  saves       Int      @default(0)
  shares      Int      @default(0)
  comments    Int      @default(0)
  likes       Int      @default(0)
  reelsViews  Int      @default(0)
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, platform, date])
  @@map("analytics_snapshots")
}

model CalendarEntry {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId    String
  date        DateTime
  title       String?
  contentType String   // "post" | "reel" | "story" | "facebook"
  status      String   @default("pending") // "posted" | "pending" | "no-content"
  postLink    String?
  caption     String?
  notes       String?
  screenshotPath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  aiReviews AIReview[]

  @@index([clientId, date])
  @@map("calendar_entries")
}

model ContentItem {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId     String
  contentType  String   // "post" | "reel" | "story" | "facebook"
  title        String?
  caption      String?
  filePath     String?
  thumbnailPath String?
  postLink     String?
  platform     String?
  postedAt     DateTime?
  engagementScore Float?
  tags         String?  // JSON array
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  aiReviews AIReview[]

  @@index([clientId, contentType])
  @@map("content_library")
}

model AIReview {
  id              String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId        String
  contentItemId   String?
  calendarEntryId String?
  screenshotPath  String?
  overallScore    Float
  designScore     Float
  marketingScore  Float
  contentScore    Float
  strengths       String   // JSON array
  weaknesses      String   // JSON array
  recommendations String   // JSON array
  rawResponse     String?
  createdAt       DateTime @default(now())

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contentItem   ContentItem?  @relation(fields: [contentItemId], references: [id])
  calendarEntry CalendarEntry? @relation(fields: [calendarEntryId], references: [id])

  @@index([clientId])
  @@map("ai_reviews")
}

model Report {
  id           String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId     String
  title        String
  month        Int
  year         Int
  summary      String?
  insights     String?  // JSON
  metrics      String?  // JSON
  pdfPath      String?
  pptxPath     String?
  createdAt    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, year, month])
  @@map("reports")
}

model Competitor {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId    String
  name        String
  platform    String
  profileUrl  String
  username    String?
  analysis    String?  // JSON
  lastAnalyzed DateTime?
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("competitors")
}

model ContentIdea {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId    String?
  title       String
  description String?
  contentType String
  platform    String?
  industry    String?
  goal        String?
  tags        String?  // JSON array
  isSaved     Boolean  @default(false)
  createdAt   DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@map("content_ideas")
}

model Notification {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  clientId  String?
  type      String   // "missing_content" | "engagement_drop" | "report_due" | "milestone"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@map("notifications")
}

model AppSettings {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
